# .ccairgap/Dockerfile — custom image extending the ccairgap base.
#
# Usage: place next to config.yaml, then reference it:
#   # config.yaml
#   dockerfile: Dockerfile
#
# You also need entrypoint.sh next to this file — copy it from the ccairgap
# package: `cp <node_modules>/ccairgap/docker/entrypoint.sh ./`. It's
# about 40 lines of bash and shouldn't need editing unless you know why.
#
# This template is Pattern 1 from references/dockerfile-patterns.md (stock recipe
# + your additions in the middle). Pattern 2 (`FROM ccairgap:<ver>`) is
# shorter but requires the base image to exist locally already.
#
# Rebuilds are triggered only when: tag missing, --rebuild passed, or the
# file's content hash changes.

FROM node:20-slim

ARG HOST_UID=1000
ARG HOST_GID=1000
ARG CLAUDE_CODE_VERSION=latest

# Stock apt packages — keep as-is unless you know you don't need one.
RUN DEBIAN_FRONTEND=noninteractive apt-get update \
 && apt-get install -y --no-install-recommends \
      git \
      git-lfs \
      curl \
      jq \
      rsync \
      ca-certificates \
      less \
      vim \
 && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# YOUR ADDITIONS GO HERE.
#
# Examples (uncomment / adapt):
#
# # Python 3 + uv (common for hooks / MCPs)
# RUN DEBIAN_FRONTEND=noninteractive apt-get update \
#  && apt-get install -y --no-install-recommends \
#       python3 python3-pip python3-venv \
#  && rm -rf /var/lib/apt/lists/*
# RUN pip3 install --break-system-packages --no-cache-dir uv
#
# # Build toolchain (common for native modules)
# RUN DEBIAN_FRONTEND=noninteractive apt-get update \
#  && apt-get install -y --no-install-recommends build-essential \
#  && rm -rf /var/lib/apt/lists/*
#
# # Playwright system deps (Chromium subset) — see references/dockerfile-patterns.md
# RUN DEBIAN_FRONTEND=noninteractive apt-get update \
#  && apt-get install -y --no-install-recommends \
#       libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
#       libdbus-1-3 libxkbcommon0 libx11-6 libxcomposite1 libxdamage1 \
#       libxext6 libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 libcairo2 libasound2 \
#  && rm -rf /var/lib/apt/lists/*
# -----------------------------------------------------------------------------

RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

# User setup — DO NOT remove. Host bind-mount ownership depends on UID/GID match.
RUN set -e; \
    if ! getent group ${HOST_GID} > /dev/null; then \
        groupadd -g ${HOST_GID} claude; \
    fi; \
    if ! getent passwd ${HOST_UID} > /dev/null; then \
        useradd -m -u ${HOST_UID} -g ${HOST_GID} -s /bin/bash claude; \
    else \
        existing=$(getent passwd ${HOST_UID} | cut -d: -f1); \
        usermod -l claude -d /home/claude -m -s /bin/bash "$existing" || true; \
    fi; \
    mkdir -p /home/claude && chown -R ${HOST_UID}:${HOST_GID} /home/claude

# Pre-create bind-mount targets so Docker doesn't create them root-owned.
RUN mkdir -p /home/claude/.claude/projects /home/claude/.claude/plugins/cache \
 && chown -R ${HOST_UID}:${HOST_GID} /home/claude

# -----------------------------------------------------------------------------
# POST-USER ADDITIONS (run as the `claude` user).
#
# For `npx playwright install`, pip install --user, cargo install, etc. that
# should land in the claude user's home:
#
# USER claude
# RUN npx playwright install chromium
# USER root
# -----------------------------------------------------------------------------

COPY --chown=claude:claude entrypoint.sh /usr/local/bin/ccairgap-entrypoint
RUN chmod +x /usr/local/bin/ccairgap-entrypoint

USER claude
WORKDIR /home/claude

ENTRYPOINT ["/usr/local/bin/ccairgap-entrypoint"]
