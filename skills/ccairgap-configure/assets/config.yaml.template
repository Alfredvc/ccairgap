# .claude-airgap/config.yaml — annotated template.
#
# Default load path: <git-root>/.claude-airgap/config.yaml
# Override: ccairgap --config <path>
#
# Precedence: CLI > config > defaults.
#
# Relative path resolution — three anchors:
#   - `repo`, `extra-repo`, `ro` → WORKSPACE ANCHOR (= git root in the canonical
#     layout; = config file's dir when --config points outside a .claude-airgap/).
#     Write these as if you were standing in the git root, not in .claude-airgap/.
#   - `dockerfile` → this config file's own directory (sidecar convention).
#   - `cp`, `sync`, `mount` → workspace repo root, resolved at launch.
#
# Delete every key you don't use. Every key below is optional.

# ---------------------------------------------------------------------------
# Repos (workspace anchor — resolve as if from the git root)
# ---------------------------------------------------------------------------

# Workspace repo (container cwd). Optional — defaults to the git root that
# contains this config file (or cwd if no config is loaded). Shown here for
# clarity; in most setups you can drop this key entirely.
#   `.`    = the git root (this config's parent dir's parent)
#   `..`   = the parent of the git root
repo: .

# Additional repos mounted and given sandbox branches. Read-write sessions.
# `../sibling-repo` = sibling of the git root (typical case).
extra-repo:
  - ../sibling-repo

# Read-only mounts. Any dir — a repo, a docs tree, reference material.
# Same anchor as `repo`/`extra-repo`: write relative to the git root.
ro:
  - ../docs
  # - /opt/reference-data          # absolute path always works

# ---------------------------------------------------------------------------
# Build artifacts (see references/artifact-decision.md)
# ---------------------------------------------------------------------------

# Copy-in at launch, discard on exit. Host original never written.
# Use when you want to seed the session with current state but not keep results.
# cp:
#   - node_modules

# Copy-in at launch, copy-out on exit to $CLAUDE_AIRGAP_HOME/output/<ts>/.
# Host original never written. Use for build outputs you want to inspect after.
sync:
  - dist

# Live RW bind mount — container writes land on host immediately.
# Use for caches where regeneration is expensive and you trust this session.
# WARNING: breaks the "host FS is immutable" invariant for the declared path.
mount:
  - node_modules

# ---------------------------------------------------------------------------
# Sandbox branch
# ---------------------------------------------------------------------------

# Base ref for the sandbox/<ts> branch. Default: current HEAD of each repo.
# base: main

# Session name. Branch becomes sandbox/<name>; also shown in `claude --resume`.
# name: feature-foo

# ---------------------------------------------------------------------------
# Container image
# ---------------------------------------------------------------------------

# Custom Dockerfile (extends base image). Sidecar anchor — resolved against
# this config file's own directory. `dockerfile: Dockerfile` = <git-root>/.claude-airgap/Dockerfile.
# dockerfile: Dockerfile

# Build args forwarded to `docker build --build-arg`.
docker-build-arg:
  CLAUDE_CODE_VERSION: "latest"  # pin to specific version for reproducibility

# Force rebuild even if the tag exists locally.
# rebuild: false

# ---------------------------------------------------------------------------
# Hooks — OFF by default inside the sandbox.
# See references/hook-patterns.md for how globs match.
# ---------------------------------------------------------------------------

hooks:
  enable:
    # Examples — delete if you want no hooks active.
    # - "python3 *"                        # all python3 hooks
    # - "bash ~/.claude/statusline.sh"     # the statusline script
    # - "*/auto-approve.py *"              # any auto-approve.py hook

# ---------------------------------------------------------------------------
# Raw docker run args (escape hatch; see references/docker-run-args.md)
# Appended after all built-ins; docker's last-wins lets you override defaults.
# ---------------------------------------------------------------------------

docker-run-arg:
  # - "-p 5173:5173"                       # publish a dev server port
  # - "--network my-net"                   # attach to a user-created network
  # - "-e OPENAI_API_KEY"                  # pass-through env var
  # - "--add-host=host.docker.internal:host-gateway"  # reach host services (linux)

# Default true — warns on dangerous tokens (--privileged, docker.sock, etc.).
# Set false to silence the warning without making those flags safe.
# warn-docker-args: true

# ---------------------------------------------------------------------------
# Session behavior
# ---------------------------------------------------------------------------

# Keep the container around after exit (omit `docker run --rm`).
# Useful for postmortem; clean up with `docker rm claude-airgap-<ts>`.
# keep-container: false

# Non-interactive prompt — makes ccairgap run once and exit.
# print: "run the test suite"
