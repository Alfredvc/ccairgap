# .claude-airgap/config.yaml — annotated template.
#
# Default load path: <git-root>/.claude-airgap/config.yaml
# Override: ccairgap --config <path>
#
# Precedence: CLI > config > defaults.
#
# Relative path resolution — three anchors:
#   - `repo`, `extra-repo`, `ro` → WORKSPACE ANCHOR (= git root in the canonical
#     layout; = config file's dir when --config points outside a .claude-airgap/).
#     Write these as if you were standing in the git root, not in .claude-airgap/.
#   - `dockerfile` → this config file's own directory (sidecar convention).
#   - `cp`, `sync`, `mount` → workspace repo root, resolved at launch.
#
# This template shows every supported key, but all are COMMENTED OUT by default.
# Uncomment only what your workflow needs. A minimal ccairgap setup is an empty
# file; adding keys is opt-in.

# ---------------------------------------------------------------------------
# Repos (workspace anchor — resolve as if from the git root)
# ---------------------------------------------------------------------------

# Workspace repo (container cwd). Optional — defaults to the git root that
# contains this config file. Most setups can drop this key.
# repo: .

# Additional repos the user is actively editing alongside the workspace.
# Each one gets its own sandbox branch; fetch-on-exit mirrors the workspace flow.
# extra-repo:
#   - ../sibling-repo

# Read-only mounts. Two use cases:
#   1. Gitignored large build/cache dirs inside the workspace — these are NOT
#      in the session clone (ccairgap clones from git), so without this mount
#      Claude sees an empty path. RO gives read access without host writes.
#      Fill in only the dirs that exist on host AND are gitignored.
#   2. Reference material outside the workspace (docs, shared-type packages).
# ro:
#   - node_modules                   # Node/Bun — gitignored, RO so imports resolve
#   - target                         # Rust — gitignored, RO so dep source is visible
#   - .venv                          # Python — gitignored
#   - dist                           # build output — RO
#   - ../docs                        # sibling docs tree
#   # - /opt/reference-data          # absolute path always works

# ---------------------------------------------------------------------------
# Build artifacts — opt-in only.
# Default is to configure NOTHING here; the container regenerates
# node_modules / .venv / target / dist from scratch. See
# references/artifact-decision.md for when to escalate.
# ---------------------------------------------------------------------------

# Copy-in at launch, discard on exit. Host original never written. Use when the
# session wants a mutable starting state but nothing should be preserved.
# cp:
#   - node_modules

# Copy-in at launch, copy-out on exit to $CLAUDE_AIRGAP_HOME/output/<ts>/.
# Host original never written. Use for build outputs you want after the session.
# sync:
#   - dist

# Live RW bind mount — container writes land on host immediately.
# WARNING: weakens the "host FS is immutable" invariant for this path.
# Only uncomment when you've explicitly decided to trust the session with a
# particular cache dir.
# mount:
#   - node_modules

# ---------------------------------------------------------------------------
# Sandbox branch
# ---------------------------------------------------------------------------

# Base ref for the sandbox/<ts> branch. Default: current HEAD of each repo.
# base: main

# Session name. Branch becomes sandbox/<name>; also shown in `claude --resume`.
# name: feature-foo

# ---------------------------------------------------------------------------
# Container image
# ---------------------------------------------------------------------------

# Custom Dockerfile (extends base image). Sidecar anchor — resolved against
# this config file's own directory. `dockerfile: Dockerfile` =
# <git-root>/.claude-airgap/Dockerfile.
# dockerfile: Dockerfile

# Build args forwarded to `docker build --build-arg`.
# docker-build-arg:
#   CLAUDE_CODE_VERSION: "latest"   # pin to a specific version for reproducibility

# Force rebuild even if the tag exists locally.
# rebuild: false

# ---------------------------------------------------------------------------
# Hooks — OFF by default inside the sandbox.
# See references/hook-patterns.md for how globs match.
# ---------------------------------------------------------------------------

# hooks:
#   enable:
#     - "python3 *"                        # all python3 hooks
#     - "bash ~/.claude/statusline.sh"     # the statusline script
#     - "*/auto-approve.py *"              # any auto-approve.py hook

# ---------------------------------------------------------------------------
# Raw docker run args — escape hatch.
#
# Do NOT add entries here speculatively. Most configs never need this section.
# Add a line only when the user has explicitly asked for the specific behavior
# (expose a port, attach to a docker network, pass a named env var, bump
# memory/CPU). See references/docker-run-args.md for the cookbook and
# references/secrets-and-sensitive-data.md before passing any credential.
# ---------------------------------------------------------------------------

# docker-run-arg:
#   - "-p 5173:5173"                       # publish a dev server port (only if user asked)
#   - "--network my-net"                   # attach to a user-created network (only if user asked)
#   - "-e OPENAI_API_KEY"                  # pass-through env var (only if user asked)

# Default true — warns on dangerous tokens (--privileged, docker.sock, etc.).
# Set false to silence the warning without making those flags safe.
# warn-docker-args: true

# ---------------------------------------------------------------------------
# Session behavior
# ---------------------------------------------------------------------------

# Keep the container around after exit (omit `docker run --rm`).
# Useful for postmortem; clean up with `docker rm claude-airgap-<ts>`.
# keep-container: false

# Non-interactive prompt — makes ccairgap run once and exit.
# print: "run the test suite"
