{
  "name": "ccairgap",
  "version": "0.2.0",
  "description": "Run Claude Code with --dangerously-skip-permissions in a Docker container. Host filesystem cannot be mutated outside a small set of explicitly writable paths.",
  "license": "MIT",
  "type": "module",
  "author": "Alfredo V. Clemente",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alfredvc/ccairgap.git"
  },
  "homepage": "https://github.com/Alfredvc/ccairgap#readme",
  "bugs": {
    "url": "https://github.com/Alfredvc/ccairgap/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "sandbox",
    "docker",
    "security",
    "agent",
    "ai",
    "cli",
    "dangerously-skip-permissions"
  ],
  "bin": {
    "ccairgap": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "docker",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm run typecheck && npm test && commit-and-tag-version"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "shell-quote": "^1.8.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/shell-quote": "^1.7.5",
    "commit-and-tag-version": "^12.7.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
